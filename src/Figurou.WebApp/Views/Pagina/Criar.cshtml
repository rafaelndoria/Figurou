@model CriarPaginaAlbumInputModel
@{
   ViewData["Title"] = "Nova Página";
   ViewData["PageTitle"] = "Cadastro de Página";
   ViewData["PageSubTitle"] = "Adicione uma nova página ao álbum.";
}

<div class="create-page-wrapper">
   <div class="create-page-card">
      <div class="create-header">
         <div>
            <h2 class="create-title">@ViewData["PageTitle"]</h2>
            <p class="create-description">@ViewData["PageSubTitle"]</p>
         </div>
         <a asp-controller="Pagina" asp-action="Index" asp-route-albumId="@Model.AlbumId" class="btn-back">
            <i class="fa-solid fa-arrow-left"></i> Voltar
         </a>
      </div>

      <form asp-controller="Pagina" asp-action="Criar" method="post" enctype="multipart/form-data">
         <input type="hidden" asp-for="AlbumId" />

         <!-- Summary de validação do ModelState e do Service -->
         <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

         <div class="form-grid">
            <div class="form-group">
               <label asp-for="NumeroPagina"></label>
               <input asp-for="NumeroPagina" type="number" min="1" class="form-input" placeholder="Número da página" />
               <span asp-validation-for="NumeroPagina" class="text-danger"></span>
            </div>

            <div class="form-group">
               <label asp-for="Largura"></label>
               <input asp-for="Largura" type="number" min="0.01" step="0.01" class="form-input" placeholder="Largura da imagem" />
               <span asp-validation-for="Largura" class="text-danger"></span>
            </div>

            <div class="form-group">
               <label asp-for="Altura"></label>
               <input asp-for="Altura" type="number" min="0.01" step="0.01" class="form-input" placeholder="Altura da imagem" />
               <span asp-validation-for="Altura" class="text-danger"></span>
            </div>

            <div class="form-group form-group-full">
               <label asp-for="Imagem"></label>
               <input asp-for="Imagem" type="file" class="form-file" accept="image/*" />
               <span asp-validation-for="Imagem" class="text-danger"></span>
            </div>

            <div class="form-group form-group-full">
               <div class="image-preview-container">
                  <img id="preview-image" class="preview-image" style="display:none;" />
               </div>
            </div>
         </div>

         <div class="form-actions">
            <button type="submit" class="btn-save">
               <i class="fa-solid fa-floppy-disk"></i>
               Salvar Página
            </button>
         </div>
      </form>
   </div>
</div>

@section Scripts {
   <partial name="_ValidationScriptsPartial" />
   <script>
      function previewImagem(event) {
          const input = event.target;
          const preview = document.getElementById('preview-image');
          if (input.files && input.files[0]) {
              const reader = new FileReader();
              reader.onload = function (e) {
                  preview.src = e.target.result;
                  preview.style.display = 'block';
              };
              reader.readAsDataURL(input.files[0]);
          }
      }
   </script>
}

<style>
   .create-page-wrapper {
      width: 100%;
   }

   .create-page-card {
      background: rgba(255,255,255,.04);
      border: 1px solid rgba(255,255,255,.06);
      border-radius: 28px;
      padding: 32px;
      backdrop-filter: blur(18px);
   }

   .create-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 35px;
      gap: 20px;
   }

   .create-title {
      font-size: 32px;
      font-weight: 700;
      color: #fff;
      margin-bottom: 8px;
   }

   .create-description {
      color: #94a3b8;
      font-size: 15px;
      margin: 0;
   }

   .btn-back {
      height: 52px;
      padding: 0 22px;
      border-radius: 16px;
      background: rgba(255,255,255,.06);
      border: 1px solid rgba(255,255,255,.08);
      color: #fff;
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 10px;
      transition: .2s;
   }

      .btn-back:hover {
         background: rgba(255,255,255,.10);
         color: #fff;
      }

   .form-grid {
      display: grid;
      grid-template-columns: repeat(2,1fr);
      gap: 24px;
   }

   .form-group {
      display: flex;
      flex-direction: column;
   }

   .form-group-full {
      grid-column: span 2;
   }

   .form-group label {
      margin-bottom: 10px;
      color: #fff;
      font-weight: 600;
   }

   .form-input {
      height: 54px;
      border-radius: 16px;
      border: 1px solid rgba(255,255,255,.08);
      background: rgba(255,255,255,.04);
      padding: 0 18px;
      color: #fff;
      outline: none;
      transition: .2s;
   }

      .form-input:focus {
         border-color: #7c3aed;
         box-shadow: 0 0 0 4px rgba(124,58,237,.15);
      }

   .form-file {
      position: relative;
      z-index: 1;
   }

   .image-preview-container {
      width: 100%;
   }

   .preview-image {
      width: 100%;
      max-height: 500px;
      object-fit: cover;
      border-radius: 24px;
      border: 1px solid rgba(255,255,255,.08);
   }

   .form-actions {
      margin-top: 35px;
      display: flex;
      justify-content: flex-end;
   }

   .btn-save {
      height: 56px;
      padding: 0 28px;
      border-radius: 18px;
      border: none;
      background: linear-gradient(135deg,#7c3aed,#2563eb);
      color: #fff;
      font-weight: 600;
      display: flex;
      align-items: center;
      gap: 12px;
      transition: .2s;
      box-shadow: 0 0 24px rgba(124,58,237,.35);
   }

      .btn-save:hover {
         transform: translateY(-2px);
      }

   .text-danger {
      margin-top: 8px;
      color: #f87171;
      font-size: 14px;
   }

   .validation-summary-errors {
      margin-bottom: 20px;
      padding: 16px;
      border-radius: 16px;
      background: rgba(239,68,68,.12);
      border: 1px solid rgba(239,68,68,.25);
      color: #fca5a5;
   }

      .validation-summary-errors ul {
         margin: 0;
         padding-left: 20px;
      }

      .validation-summary-errors li {
         margin: 4px 0;
      }
   @@media(max - width:768px) {
      .form-grid

   {
      grid-template-columns: 1fr;
   }

   .form-group-full {
      grid-column: span 1;
   }

   .btn-back, .btn-save {
      width: 100%;
      justify-content: center;
   }

   .form-actions {
      justify-content: stretch;
   }

   }
</style>