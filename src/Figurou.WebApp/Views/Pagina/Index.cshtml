@model PaginaAlbumViewModel
@{
   ViewData["Title"] = "Páginas do Álbum";
   ViewData["PageTitle"] = "Gerenciamento de Páginas do Álbum";
   ViewData["PageSubTitle"] = "Gerencie as páginas do álbum.";
}

<div class="page-header-custom">

   <div>

      <h2 class="album-name">
         @(Model?.NomeAlbum ?? "Álbum")
      </h2>

      <span class="album-subtitle">
         Total de páginas: @(Model?.Paginas?.Count() ?? 0)
      </span>

   </div>

   <a asp-controller="Pagina"
      asp-action="Criar"
      asp-route-albumId="@Model?.AlbumId"
      class="btn-create-page">

      <i class="fa-solid fa-plus"></i>
      Nova Página

   </a>

</div>

<partial name="_ListaPaginas"
         model="Model?.Paginas ?? Enumerable.Empty<PaginaAlbumItemViewModel>()" />

<style>

   .page-header-custom {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 35px;
      gap: 20px;
   }

   .album-name {
      font-size: 32px;
      font-weight: 700;
      color: #fff;
      margin-bottom: 8px;
   }

   .album-subtitle {
      color: #94a3b8;
      font-size: 14px;
   }

   .btn-create-page {
      height: 56px;
      padding: 0 26px;
      border-radius: 18px;
      border: none;
      text-decoration: none;
      background: linear-gradient(135deg, #7c3aed, #2563eb);
      color: #fff;
      display: flex;
      align-items: center;
      gap: 10px;
      font-weight: 600;
      transition: .2s;
      box-shadow: 0 0 25px rgba(124,58,237,.35);
   }

      .btn-create-page:hover {
         transform: translateY(-2px);
         color: #fff;
      }

</style>