@model LoginUsuarioInputModel;
@{
   Layout = null;
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
   <meta charset="UTF-8">
   <meta name="viewport" content="width=device-width, initial-scale=1.0">
   <title>Figurou - Login</title>

   <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">
   <link rel="stylesheet" href="~/css/login.css" />
</head>

<body>

   <div class="background-glow"></div>

   <div class="login-wrapper">

      <div class="login-card">

         <div class="text-center">

            <span class="logo-badge">
               FIGUROU
            </span>

            <h1 class="login-title">
               Bem-vindo
            </h1>

            <p class="login-subtitle">
               Entre na sua conta e continue sua coleção.
            </p>

         </div>

         <form asp-controller="Usuario"
               asp-action="Login"
               method="post">

            @Html.Partial("_ErrorSummary")

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-4">

               <label asp-for="Username" class="form-label"></label>

               <input asp-for="Username"
                      class="custom-input"
                      placeholder="Digite seu username ou e-mail">

               <span asp-validation-for="Username" class="text-danger"></span>

            </div>

            <div class="mb-4">

               <label asp-for="Senha" class="form-label"></label>

               <input asp-for="Senha"
                      type="password"
                      class="custom-input"
                      placeholder="Digite sua senha">

               <span asp-validation-for="Senha" class="text-danger"></span>

            </div>

            <div class="d-flex justify-content-between align-items-center mb-4">

               <div class="form-check">

                  <input asp-for="LembrarConta"
                         class="form-check-input">

                  <label asp-for="LembrarConta"
                         class="form-check-label text-light">
                  </label>

               </div>

               @* TODO - adicionar metodo para recuperar senha *@
               <a href="#" class="link-default">
                  Esqueci minha senha
               </a>

            </div>

            <button type="submit" class="btn-login">
               Entrar na plataforma
            </button>

         </form>

         <div class="divider">
            ou
         </div>

         <div class="bottom-text">

            Ainda não possui conta?

            <a asp-controller="Usuario" asp-action="Registrar" class="link-default">
               Criar conta
            </a>

         </div>

      </div>

   </div>

   <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js"></script>

   <partial name="_ValidationScriptsPartial" />

</body>
</html>