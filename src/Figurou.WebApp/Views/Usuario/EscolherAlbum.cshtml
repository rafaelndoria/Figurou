@model IEnumerable<AlbumViewModel>
@{
   ViewData["Title"] = "Escolher Álbum";
   ViewData["PageTitle"] = "Escolher Álbum";
   ViewData["PageSubTitle"] = "Selecione o álbum que deseja utilizar.";
}

<div class="album-selection-container">

   @if (!Model.Any())
   {
      <div class="empty-albums">

         <i class="fa-regular fa-image"></i>

         <h3>Nenhum álbum disponível</h3>

         <p>
            Não existem álbuns ativos no momento.
         </p>

      </div>
   }
   else
   {
      <div class="albums-grid">

         @foreach (var album in Model)
         {
            <div class="album-card">

               <div class="album-cover">
                  <img src="@album.Capa" alt="@album.Nome" />
               </div>

               <div class="album-content">

                  <h3>@album.Nome</h3>

                  <span class="album-year">
                     @album.Ano
                  </span>

                  <p>
                     @album.Descricao
                  </p>

                  <div class="album-info">
                     <span>
                        @album.TotalFigurinhas Figurinhas
                     </span>
                  </div>

               </div>

               <div class="album-actions">

                  @if (!album.UsuarioSelecionado)
                  {
                     <form asp-controller="Usuario"
                           asp-action="EscolherAlbum"
                           asp-route-albumId="@album.Id"
                           method="post">

                        <button type="submit"
                                class="btn-select">

                           <i class="fa-solid fa-check"></i>
                           Escolher

                        </button>

                     </form>
                  }
                  else
                  {
                     <form asp-controller="Usuario"
                           asp-action="RemoverAlbum"
                           asp-route-albumId="@album.Id"
                           method="post">

                        <button type="submit"
                                class="btn-select"
                                style="background: linear-gradient(135deg,#ef4444,#dc2626);">

                           <i class="fa-solid fa-trash"></i>
                           Remover

                        </button>

                     </form>
                  }

               </div>

            </div>
         }

      </div>
   }

</div>

<style>

   .album-selection-container {
      max-width: 1400px;
      margin: auto;
   }

   .albums-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 24px;
   }

   .album-card {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 24px;
      overflow: hidden;
      transition: .2s;
      display: flex;
      flex-direction: column;
   }

   .album-card:hover {
      transform: translateY(-4px);
      border-color: rgba(124,58,237,.4);
   }

   .album-cover {
      height: 260px;
      overflow: hidden;
   }

   .album-cover img {
      width: 100%;
      height: 100%;
      object-fit: cover;
   }

   .album-content {
      padding: 20px;
      flex: 1;
   }

   .album-content h3 {
      color: #fff;
      margin-bottom: 5px;
   }

   .album-year {
      color: #94a3b8;
      font-size: 14px;
   }

   .album-content p {
      margin-top: 15px;
      color: #cbd5e1;
      font-size: 14px;
      min-height: 70px;
   }

   .album-info {
      margin-top: 15px;
      color: #a78bfa;
      font-weight: 600;
   }

   .album-actions {
      padding: 20px;
      border-top: 1px solid rgba(255,255,255,0.08);
   }

   .btn-select {
      width: 100%;
      height: 52px;
      border: none;
      border-radius: 16px;
      background: linear-gradient(135deg,#7c3aed,#2563eb);
      color: white;
      font-weight: 600;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      transition: .2s;
   }

   .btn-select:hover {
      transform: translateY(-2px);
   }

   .empty-albums {
      text-align: center;
      padding: 80px 20px;
      color: #94a3b8;
   }

   .empty-albums i {
      font-size: 60px;
      margin-bottom: 20px;
   }

</style>