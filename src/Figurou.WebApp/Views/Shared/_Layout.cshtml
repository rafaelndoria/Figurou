<!DOCTYPE html>
<html lang="pt-br">
<head>
   <meta charset="utf-8" />
   <meta name="viewport" content="width=device-width, initial-scale=1.0" />
   <title>@ViewData["Title"] - Figurou</title>
   <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">
   <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
   <link rel="preconnect" href="https://fonts.googleapis.com">
   <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
   <script src="https://kit.fontawesome.com/4f2b7c7e15.js" crossorigin="anonymous"></script>
</head>

<body>
   <div class="background-glow glow-1"></div>
   <div class="background-glow glow-2"></div>
   <div class="dashboard-container">
      <!-- SIDEBAR -->
      <aside class="sidebar">
         <div>
            <div class="sidebar-logo">
               FIGUROU
            </div>
            <!-- MENU -->
            <div class="sidebar-section">
               MENU
            </div>
            <nav class="sidebar-nav">
               <a href="/dashboard" class="sidebar-link active">
                  <i class="fa-solid fa-chart-line"></i>
                  <span>Dashboard</span>
               </a>
               <a href="/album/meu-album" class="sidebar-link">
                  <i class="fa-solid fa-book"></i>
                  <span>Meu Álbum</span>
               </a>
               <a href="/album/virtual" class="sidebar-link">
                  <i class="fa-solid fa-images"></i>
                  <span>Álbum Virtual</span>
               </a>
               <a href="/leitura-ia/pagina" class="sidebar-link">
                  <i class="fa-solid fa-camera"></i>
                  <span>Leitura IA</span>
               </a>
               <a href="/match/encontrar" class="sidebar-link">
                  <i class="fa-solid fa-users"></i>
                  <span>Match</span>
               </a>
               <a href="/trocas" class="sidebar-link">
                  <i class="fa-solid fa-right-left"></i>
                  <span>Trocas</span>
               </a>
               <a href="/mensagens" class="sidebar-link">
                  <i class="fa-solid fa-message"></i>
                  <span>Mensagens</span>
            </nav>
            <!-- ADMIN -->
            <div class="sidebar-section mt-4">
               ADMIN
            </div>
            <nav class="sidebar-nav">
               <a asp-controller="Album" asp-action="Index" class="sidebar-link">
                  <i class="fa-solid fa-book-open"></i>
                  <span>Álbuns</span>
               </a>
               <a href="/admin/figurinhas" class="sidebar-link">
                  <i class="fa-solid fa-images"></i>
                  <span>Figurinhas</span>
               </a>
               <a href="/admin/selecoes" class="sidebar-link">
                  <i class="fa-solid fa-flag"></i>
                  <span>Seleções</span>
               </a>
            </nav>
         </div>
         <!-- FOOTER -->
         <div class="sidebar-footer">
            <a href="/configuracoes" class="sidebar-link">
               <i class="fa-solid fa-gear"></i>
               <span>Configurações</span>
            </a>
            <a href="/sair" class="sidebar-link text-danger">
               <i class="fa-solid fa-arrow-right-from-bracket"></i>
               <span>Sair</span>
            </a>
         </div>
      </aside>
      <!-- OVERLAY -->
      <div class="sidebar-overlay" id="sidebarOverlay"></div>
      <!-- CONTENT -->
      <div class="dashboard-content">
         <!-- TOPBAR -->
         <header class="topbar">
            <div class="d-flex align-items-center gap-3">
               <button class="mobile-menu-btn" id="mobileMenuBtn">
                  <i class="fa-solid fa-bars"></i>
               </button>
               <div>
                  <h1 class="page-title">
                     @ViewData["PageTitle"]
                  </h1>
                  <span class="page-subtitle">
                     @ViewData["PageSubTitle"]
                  </span>
               </div>
            </div>
            <div class="topbar-actions">
               <button class="icon-button">
                  <i class="fa-solid fa-bell"></i>
               </button>
               <button class="icon-button">
                  <i class="fa-solid fa-envelope"></i>
               </button>
               <div class="profile-area">
                  <div class="profile-avatar">
                     R
                  </div>
                  <div>
                     <div class="profile-name">
                        Rafael
                     </div>
                     <div class="profile-role">
                        Administrador
                     </div>
                  </div>
               </div>
            </div>
         </header>

         <!-- MAIN -->
         <main class="main-content">
            @RenderBody()
         </main>

         <!-- POPUP UNIVERSAL DE NOTIFICAÇÃO -->
         <div id="globalPopup" class="popup-notification" style="display:none;">
            <div class="popup-content">
               <div class="popup-header">
                  <h4>Notificações</h4>
                  <button type="button" class="close-btn" onclick="closePopup()">×</button>
               </div>
               <div class="popup-body">
                  <ul id="popup-messages">
                     @if (!string.IsNullOrEmpty(ViewBag.Sucesso))
                     {
                        <li class="popup-success">@ViewBag.Sucesso</li>
                     }
                     @foreach (var item in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                     {
                        <li class="popup-error">@item.ErrorMessage</li>
                     }
                  </ul>
               </div>
            </div>
         </div>
      </div>
   </div>

   <script src="~/lib/jquery/dist/jquery.min.js"></script>
   <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
   <!-- MENU MOBILE -->

   <script>

      const mobileMenuBtn = document.getElementById('mobileMenuBtn');
      const sidebar = document.querySelector('.sidebar');
      const overlay = document.getElementById('sidebarOverlay');

      mobileMenuBtn.addEventListener('click', () => {

         sidebar.classList.toggle('sidebar-open');
         overlay.classList.toggle('overlay-show');

      });

      overlay.addEventListener('click', () => {

         sidebar.classList.remove('sidebar-open');
         overlay.classList.remove('overlay-show');

      });

   </script>

   <script>
      function closePopup() {
         document.getElementById('globalPopup').style.display = 'none';
      }

      document.addEventListener("DOMContentLoaded", function() {
         const popup = document.getElementById('globalPopup');
         const hasErrors = document.querySelectorAll('.popup-error').length > 0;
         const hasSuccess = document.querySelectorAll('.popup-success').length > 0;

         if(hasErrors || hasSuccess) {
            popup.style.display = 'block';
            // Fecha automaticamente após 7 segundos
            setTimeout(() => {
               popup.style.display = 'none';
            }, 7000);
         }
      });
   </script>

   @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
