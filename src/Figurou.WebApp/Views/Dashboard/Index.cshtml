@{
   ViewData["Title"] = "Dashboard";
   ViewData["PageTitle"] = "Dashboard";
   ViewData["PageSubTitle"] = "Bem-vindo novamente ao Figurou.";
}

<div class="row g-4">

   <div class="col-md-3">

      <div class="dashboard-card">

         <span class="card-icon">
            <i class="fa-solid fa-images"></i>
         </span>

         <div class="card-title">
            Figurinhas
         </div>

         <div class="card-value">
            1.284
         </div>

      </div>

   </div>

   <div class="col-md-3">

      <div class="dashboard-card">

         <span class="card-icon">
            <i class="fa-solid fa-repeat"></i>
         </span>

         <div class="card-title">
            Trocas
         </div>

         <div class="card-value">
            48
         </div>

      </div>

   </div>

   <div class="col-md-3">

      <div class="dashboard-card">

         <span class="card-icon">
            <i class="fa-solid fa-user-group"></i>
         </span>

         <div class="card-title">
            Matches
         </div>

         <div class="card-value">
            96
         </div>

      </div>

   </div>

   <div class="col-md-3">

      <div class="dashboard-card">

         <span class="card-icon">
            <i class="fa-solid fa-camera"></i>
         </span>

         <div class="card-title">
            Leituras IA
         </div>

         <div class="card-value">
            328
         </div>

      </div>

   </div>

</div>

<div class="row mt-4 g-4">

   <div class="col-lg-8">

      <div class="content-card">

         <div class="content-card-header">

            <h2>
               Atividade recente
            </h2>

            <a href="#">
               Ver tudo
            </a>

         </div>

         <div class="activity-list">

            <div class="activity-item">
               <div>
                  <strong>Nova troca realizada</strong>
                  <p>Você concluiu uma troca com João.</p>
               </div>

               <span>2 min</span>
            </div>

            <div class="activity-item">
               <div>
                  <strong>Leitura IA concluída</strong>
                  <p>12 figurinhas adicionadas automaticamente.</p>
               </div>

               <span>10 min</span>
            </div>

            <div class="activity-item">
               <div>
                  <strong>Novo match encontrado</strong>
                  <p>Encontramos alguém com suas faltantes.</p>
               </div>

               <span>1 hora</span>
            </div>

         </div>

      </div>

   </div>

   <div class="col-lg-4">

      <div class="content-card">

         <div class="content-card-header">

            <h2>
               Progresso do álbum
            </h2>

         </div>

         <div class="progress-area">

            <div class="progress-circle">
               78%
            </div>

            <p>
               Você já completou 78% do álbum.
            </p>

         </div>

      </div>

   </div>

</div>