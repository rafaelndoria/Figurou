@model AtualizarAlbumInputModel
@{
   ViewData["Title"] = "Editar Álbum";
}

<div class="page-header">

   <div>
      <h1 class="page-title">Editar Álbum</h1>
      <p class="page-subtitle">
         Atualize as informações do álbum
      </p>
   </div>

   <a asp-controller="Album" asp-action="Index" class="btn-back">
      <i class="fa-solid fa-arrow-left"></i>
      Voltar
   </a>

</div>

<form asp-controller="Album"
      asp-action="Editar"
      asp-route-id="@Model.Id"
      method="post"
      enctype="multipart/form-data"
      class="album-form">

   <input asp-for="Id" type="hidden" />
   <input asp-for="Caminho" type="hidden" />

   <div class="form-grid">

      <div class="glass-card">

         <div class="form-group">

            <label>Nome do Álbum</label>

            <input asp-for="Nome"
                   class="form-input" />

            <span asp-validation-for="Nome"
                  class="text-danger"></span>

         </div>

         <div class="form-row">

            <div class="form-group">

               <label>Ano</label>

               <input asp-for="Ano"
                      type="number"
                      class="form-input" />

               <span asp-validation-for="Ano"
                     class="text-danger"></span>

            </div>

            <div class="form-group">

               <label>Total de Figurinhas</label>

               <input asp-for="TotalFigurinhas"
                      type="number"
                      class="form-input" />

               <span asp-validation-for="TotalFigurinhas"
                     class="text-danger"></span>

            </div>

         </div>

         <div class="form-group">

            <label>Descrição</label>

            <textarea asp-for="Descricao"
                      rows="6"
                      class="form-input textarea"></textarea>

            <span asp-validation-for="Descricao"
                  class="text-danger"></span>

         </div>

      </div>

      <div class="glass-card">

         <label class="cover-label">
            Capa do Álbum
         </label>

         <div class="cover-preview">

            <img id="preview-image"
                 src="@Model.Caminho"
                 alt="Capa do álbum" />

         </div>

         <div class="form-group">

            <label>Alterar Capa</label>

            <input asp-for="ImagemCapa"
                   type="file"
                   accept="image/*"
                   class="form-input"
                   onchange="previewImage(event)" />

         </div>

      </div>

   </div>

   <div class="form-actions">

      <button type="submit" class="btn-save">

         <i class="fa-solid fa-floppy-disk"></i>
         Salvar Alterações

      </button>

   </div>

</form>

@section Scripts {

   <partial name="_ValidationScriptsPartial" />

   <script>

      function previewImage(event) {

          const input = event.target;
          const preview = document.getElementById('preview-image');

          if (input.files && input.files[0]) {

              preview.src = URL.createObjectURL(input.files[0]);

          }
      }

   </script>
}

<style>

   .page-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 32px;
      gap: 20px;
   }

   .page-title {
      color: #fff;
      font-size: 32px;
      font-weight: 700;
      margin: 0;
   }

   .page-subtitle {
      color: #9ca3af;
      margin-top: 6px;
   }

   .btn-back {
      padding: 12px 18px;
      border-radius: 14px;
      text-decoration: none;
      background: rgba(255,255,255,.08);
      color: #fff;
      display: flex;
      align-items: center;
      gap: 10px;
      transition: .2s;
   }

      .btn-back:hover {
         background: rgba(255,255,255,.14);
         color: #fff;
      }

   .album-form {
      width: 100%;
   }

   .form-grid {
      display: grid;
      grid-template-columns: 2fr 1fr;
      gap: 24px;
   }

   .glass-card {
      background: rgba(255,255,255,.05);
      border: 1px solid rgba(255,255,255,.06);
      border-radius: 24px;
      padding: 24px;
      backdrop-filter: blur(20px);
   }

   .form-group {
      display: flex;
      flex-direction: column;
      margin-bottom: 22px;
   }

   .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 18px;
   }

   .form-group label,
   .cover-label {
      color: #fff;
      margin-bottom: 10px;
      font-weight: 600;
   }

   .form-input {
      width: 100%;
      border: none;
      outline: none;
      border-radius: 14px;
      padding: 14px 16px;
      background: rgba(255,255,255,.06);
      color: #fff;
      font-size: 15px;
      transition: .2s;
   }

      .form-input:focus {
         border: 1px solid rgba(124,58,237,.6);
         background: rgba(255,255,255,.08);
      }

   .textarea {
      resize: none;
   }

   .cover-preview {
      width: 100%;
      height: 420px;
      border-radius: 22px;
      overflow: hidden;
      margin-bottom: 20px;
      background: rgba(255,255,255,.04);
   }

      .cover-preview img {
         width: 100%;
         height: 100%;
         object-fit: cover;
      }

   .form-actions {
      margin-top: 28px;
      display: flex;
      justify-content: flex-end;
   }

   .btn-save {
      border: none;
      border-radius: 16px;
      padding: 16px 26px;
      background: linear-gradient(135deg,#7c3aed,#4f46e5);
      color: #fff;
      font-weight: 600;
      display: flex;
      align-items: center;
      gap: 12px;
      transition: .2s;
      cursor: pointer;
   }

      .btn-save:hover {
         transform: translateY(-2px);
         opacity: .95;
      }

   .text-danger {
      color: #f87171;
      margin-top: 8px;
      font-size: 14px;
   }

   @@media(max-width:992px) {

      .form-grid {
         grid-template-columns: 1fr;
      }

      .cover-preview {
         height: 320px;
      }
   }

   @@media(max-width:768px) {

      .page-header {
         flex-direction: column;
         align-items: flex-start;
      }

      .form-row {
         grid-template-columns: 1fr;
      }
   }

</style>