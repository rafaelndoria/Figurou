@model IEnumerable<AlbumViewModel>
@{
   ViewData["Title"] = "Álbuns";
   ViewData["PageTitle"] = "Gerenciamento de Álbuns";
   ViewData["PageSubTitle"] = "Cadastre e gerencie os álbuns.";
}

<div class="albums-page">

   <div class="albums-header">

      <a asp-controller="Album" asp-action="Criar" class="btn-create">
         <i class="fa-solid fa-plus"></i>
         Novo Álbum
      </a>

   </div>

   <partial name="_ListaAlbuns" model="Model" />

</div>

<style>

   .albums-header{
       display:flex;
       justify-content:flex-start;
       margin-bottom:25px;
   }

   .btn-create{
       border:none;
       background:linear-gradient(135deg, #7c3aed, #2563eb);
       color:#fff;
       padding:14px 22px;
       border-radius:16px;
       text-decoration:none;
       font-weight:600;
       display:flex;
       align-items:center;
       gap:10px;
       transition:.2s;
       box-shadow:0 0 25px rgba(124,58,237,.35);
   }

   .btn-create:hover{
       transform:translateY(-2px);
       color:#fff;
   }

</style>
